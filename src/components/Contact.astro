---
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contacto" class="py-24 bg-surface px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-accent text-sm font-medium tracking-widest uppercase mb-4">{t('contact.label')}</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">{t('contact.title')}</h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">{t('contact.subtitle')}</p>
    </div>
    <div class="max-w-2xl mx-auto">
      <form
        id="contact-form"
        action="/api/contact"
        method="POST"
        class="space-y-5"
        data-sending={t('contact.sending')}
        data-success={t('contact.success')}
        data-error={t('contact.error')}
        data-submit={t('contact.submit')}
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">{t('contact.name')}</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">{t('contact.email')}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
            />
          </div>
        </div>
        <div>
          <label for="company" class="block text-sm font-medium text-gray-700 mb-1.5">{t('contact.company')}</label>
          <input
            type="text"
            id="company"
            name="company"
            class="w-full px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">{t('contact.message')}</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors resize-none"
          ></textarea>
        </div>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAAC00cdgZ2EPRj8rf" data-theme="light"></div>
        <div class="flex items-center gap-4">
          <button
            type="submit"
            id="contact-submit"
            class="px-7 py-3 bg-accent text-white font-medium rounded-full hover:bg-accent-hover transition-all duration-300 hover:scale-[1.02] text-sm disabled:opacity-50 disabled:hover:scale-100"
          >
            {t('contact.submit')}
          </button>
          <p id="contact-status" class="text-sm hidden"></p>
        </div>
      </form>

      <div class="mt-10 pt-8 border-t border-gray-200 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-500">
        <span>📍 Valencia</span>
        <span class="hidden sm:inline text-gray-300">|</span>
        <a href="mailto:info@mxmn.net" class="text-accent hover:text-accent-hover transition-colors">{t('contact.info.email')}</a>
        <span class="hidden sm:inline text-gray-300">|</span>
        <a
          href="https://maps.google.com/?q=Avda.+Burjassot+11,+46009+Valencia"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:text-accent-hover transition-colors inline-flex items-center gap-1"
        >
          {t('contact.info.map')}
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('contact-submit') as HTMLButtonElement;
  const status = document.getElementById('contact-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const { sending, success, error, submit } = form.dataset;

    btn.disabled = true;
    btn.textContent = sending!;
    status.classList.add('hidden');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });

      if (res.ok) {
        status.textContent = success!;
        status.className = 'text-sm text-green-600';
        form.reset();
      } else {
        status.textContent = error!;
        status.className = 'text-sm text-red-500';
      }
    } catch {
      status.textContent = error!;
      status.className = 'text-sm text-red-500';
    }

    btn.disabled = false;
    btn.textContent = submit!;
  });
</script>
