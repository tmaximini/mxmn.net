---
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="min-h-screen flex items-center justify-center pt-16 pb-24 px-6 relative overflow-hidden">
  <canvas id="hero-canvas" class="absolute inset-0 pointer-events-none" aria-hidden="true"></canvas>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <p class="text-accent text-sm font-medium tracking-widest uppercase mb-6 animate-fade-up">
      {t('hero.label')}
    </p>
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight text-gray-900 animate-fade-up animate-fade-up-delay-1">
      {t('hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed animate-fade-up animate-fade-up-delay-2">
      {t('hero.subtitle')}
    </p>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up animate-fade-up-delay-3">
      <a
        href="#contacto"
        class="px-7 py-3 bg-accent text-white font-medium rounded-full hover:bg-accent-hover transition-all duration-300 hover:scale-[1.02] text-sm"
      >
        {t('hero.cta.primary')}
      </a>
      <a
        href="#soluciones"
        class="px-7 py-3 border border-gray-300 text-gray-700 font-medium rounded-full hover:border-gray-900 hover:text-gray-900 transition-all duration-300 text-sm"
      >
        {t('hero.cta.secondary')}
      </a>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const section = canvas.parentElement!;

  let mouseX = 0.5;
  let mouseY = 0.5;
  let curX = 0.5;
  let curY = 0.5;
  let w = 0;
  let h = 0;

  interface Pt { bx: number; by: number; x: number; y: number }

  let pts: Pt[] = [];
  let tris: number[][] = [];
  let colors: string[] = [];

  // Simple seeded random for consistent pattern
  let seed = 42;
  function rand() {
    seed = (seed * 16807 + 0) % 2147483647;
    return (seed - 1) / 2147483646;
  }

  // Delaunay triangulation (Bowyer-Watson)
  function triangulate(points: { x: number; y: number }[]): number[][] {
    const st0 = { x: -1e4, y: -1e4 };
    const st1 = { x: 1e4, y: -1e4 };
    const st2 = { x: 0, y: 1e4 };
    const all = [...points, st0, st1, st2];
    const n = points.length;

    let triangles: number[][] = [[n, n + 1, n + 2]];

    for (let i = 0; i < n; i++) {
      const px = all[i].x, py = all[i].y;
      const bad: number[] = [];

      for (let t = 0; t < triangles.length; t++) {
        const [a, b, c] = triangles[t];
        const ax = all[a].x, ay = all[a].y;
        const bx = all[b].x, by = all[b].y;
        const cx = all[c].x, cy = all[c].y;

        const d = 2 * (ax * (by - cy) + bx * (cy - ay) + cx * (ay - by));
        if (Math.abs(d) < 1e-10) continue;
        const ux = ((ax * ax + ay * ay) * (by - cy) + (bx * bx + by * by) * (cy - ay) + (cx * cx + cy * cy) * (ay - by)) / d;
        const uy = ((ax * ax + ay * ay) * (cx - bx) + (bx * bx + by * by) * (ax - cx) + (cx * cx + cy * cy) * (bx - ax)) / d;
        const r2 = (ax - ux) * (ax - ux) + (ay - uy) * (ay - uy);

        if ((px - ux) * (px - ux) + (py - uy) * (py - uy) < r2) {
          bad.push(t);
        }
      }

      // Find boundary polygon of bad triangles
      const edges: [number, number][] = [];
      for (const t of bad) {
        const tri = triangles[t];
        for (let j = 0; j < 3; j++) {
          const e: [number, number] = [tri[j], tri[(j + 1) % 3]];
          const shared = bad.some(
            (t2) => t2 !== t && triangles[t2].includes(e[0]) && triangles[t2].includes(e[1])
          );
          if (!shared) edges.push(e);
        }
      }

      // Remove bad triangles (reverse order)
      for (let j = bad.length - 1; j >= 0; j--) {
        triangles.splice(bad[j], 1);
      }

      for (const [a, b] of edges) {
        triangles.push([i, a, b]);
      }
    }

    // Remove triangles that use super-triangle vertices
    return triangles.filter((t) => t[0] < n && t[1] < n && t[2] < n);
  }

  // Color for a triangle based on centroid position
  function triColor(cx: number, cy: number): string {
    // Subtle gradient: light gray to very light blue
    const t = cx / w;  // 0..1 left to right
    const u = cy / h;  // 0..1 top to bottom

    // Base: light with subtle blue shift, more contrast
    const r = Math.round(222 + (1 - t) * 18 - u * 10 + rand() * 12);
    const g = Math.round(226 + (1 - t) * 14 - u * 8 + rand() * 12);
    const b = Math.round(235 + t * 10 - u * 5 + rand() * 10);

    return `rgb(${Math.min(255, r)}, ${Math.min(255, g)}, ${Math.min(255, b)})`;
  }

  function buildMesh() {
    seed = 42;
    pts = [];
    const cellSize = 80;
    const jitter = cellSize * 0.65;
    const cols = Math.ceil(w / cellSize) + 4;
    const rows = Math.ceil(h / cellSize) + 4;
    const ox = -cellSize * 2;
    const oy = -cellSize * 2;

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        pts.push({
          bx: ox + c * cellSize + (rand() - 0.5) * jitter,
          by: oy + r * cellSize + (rand() - 0.5) * jitter,
          x: 0,
          y: 0,
        });
      }
    }

    tris = triangulate(pts.map((p) => ({ x: p.bx, y: p.by })));

    // Pre-compute colors
    colors = tris.map((t) => {
      const cx = (pts[t[0]].bx + pts[t[1]].bx + pts[t[2]].bx) / 3;
      const cy = (pts[t[0]].by + pts[t[1]].by + pts[t[2]].by) / 3;
      return triColor(cx, cy);
    });
  }

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = section.offsetWidth;
    h = section.offsetHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    buildMesh();
  }

  section.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = section.getBoundingClientRect();
    mouseX = (e.clientX - rect.left) / rect.width;
    mouseY = (e.clientY - rect.top) / rect.height;
  });

  section.addEventListener('mouseleave', () => {
    mouseX = 0.5;
    mouseY = 0.5;
  });

  function animate() {
    curX += (mouseX - curX) * 0.03;
    curY += (mouseY - curY) * 0.03;

    const shiftX = (curX - 0.5) * 20;
    const shiftY = (curY - 0.5) * 20;

    // Update positions: parallax increases with distance from center
    const cx = w / 2, cy = h / 2;
    for (const p of pts) {
      const dx = (p.bx - cx) / w;
      const dy = (p.by - cy) / h;
      const factor = 1 + Math.sqrt(dx * dx + dy * dy) * 1.5;
      p.x = p.bx + shiftX * factor;
      p.y = p.by + shiftY * factor;
    }

    ctx.clearRect(0, 0, w, h);

    // Draw filled triangles
    for (let i = 0; i < tris.length; i++) {
      const [a, b, c] = tris[i];
      ctx.beginPath();
      ctx.moveTo(pts[a].x, pts[a].y);
      ctx.lineTo(pts[b].x, pts[b].y);
      ctx.lineTo(pts[c].x, pts[c].y);
      ctx.closePath();
      ctx.fillStyle = colors[i];
      ctx.fill();
      ctx.strokeStyle = 'rgba(200, 208, 220, 0.4)';
      ctx.lineWidth = 0.5;
      ctx.stroke();
    }

    // Fade bottom edge into the surface color (#F5F7FA)
    const fadeH = h * 0.35;
    const grad = ctx.createLinearGradient(0, h - fadeH, 0, h);
    grad.addColorStop(0, 'rgba(245, 247, 250, 0)');
    grad.addColorStop(1, 'rgba(245, 247, 250, 1)');
    ctx.fillStyle = grad;
    ctx.fillRect(0, h - fadeH, w, fadeH);

    requestAnimationFrame(animate);
  }

  resize();
  window.addEventListener('resize', resize);
  animate();
</script>
