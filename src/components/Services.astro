---
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  {
    title: t('services.platforms.title'),
    description: t('services.platforms.description'),
    color: { bg: 'rgba(99,102,241,0.07)', border: 'rgba(99,102,241,0.15)', icon: '#6366f1', glow: 'rgba(99,102,241,0.12)', gradient: 'from-indigo-500/80 to-violet-500/80' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2 9.5V4a2 2 0 012-2h16a2 2 0 012 2v5.5M2 9.5h20M2 9.5v8a2 2 0 002 2h16a2 2 0 002-2v-8M8 14h8" />`,
  },
  {
    title: t('services.management.title'),
    description: t('services.management.description'),
    color: { bg: 'rgba(16,185,129,0.07)', border: 'rgba(16,185,129,0.15)', icon: '#10b981', glow: 'rgba(16,185,129,0.12)', gradient: 'from-emerald-500/80 to-teal-500/80' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
  },
  {
    title: t('services.commerce.title'),
    description: t('services.commerce.description'),
    color: { bg: 'rgba(245,158,11,0.07)', border: 'rgba(245,158,11,0.15)', icon: '#f59e0b', glow: 'rgba(245,158,11,0.12)', gradient: 'from-amber-500/80 to-orange-500/80' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.5.5-.1 1.4.6 1.4H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />`,
  },
  {
    title: t('services.ai.title'),
    description: t('services.ai.description'),
    color: { bg: 'rgba(168,85,247,0.07)', border: 'rgba(168,85,247,0.15)', icon: '#a855f7', glow: 'rgba(168,85,247,0.12)', gradient: 'from-purple-500/80 to-fuchsia-500/80' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.3 24.3 0 014.5 0m0 0v5.714a2.25 2.25 0 00.659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M5 14.5l-1.43 1.43a2.25 2.25 0 000 3.18l.14.14a2.25 2.25 0 003.18 0L8.5 17.5m-3.5-3h3.75m6.25 0l1.43 1.43a2.25 2.25 0 010 3.18l-.14.14a2.25 2.25 0 01-3.18 0L15.5 17.5m3.5-3h-3.75m-4.5 0v3.5" />`,
  },
  {
    title: t('services.integrations.title'),
    description: t('services.integrations.description'),
    color: { bg: 'rgba(244,63,94,0.07)', border: 'rgba(244,63,94,0.15)', icon: '#f43f5e', glow: 'rgba(244,63,94,0.12)', gradient: 'from-rose-500/80 to-pink-500/80' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.143-3.25a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />`,
  },
  {
    title: t('services.mobile.title'),
    description: t('services.mobile.description'),
    color: { bg: 'rgba(14,165,233,0.07)', border: 'rgba(14,165,233,0.15)', icon: '#0ea5e9', glow: 'rgba(14,165,233,0.12)', gradient: 'from-sky-500/80 to-cyan-500/80' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 2h8a2 2 0 012 2v16a2 2 0 01-2 2H8a2 2 0 01-2-2V4a2 2 0 012-2zm4 17h.01" />`,
  },
];
---

<section id="soluciones" class="py-24 bg-surface px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-accent text-sm font-medium tracking-widest uppercase mb-4">{t('services.label')}</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">{t('services.title')}</h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">{t('services.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((service, i) => (
        <div
          class="service-card group relative bg-white rounded-2xl p-8 border border-gray-200/80 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1.5 overflow-hidden"
          style={`animation-delay: ${i * 80}ms`}
        >
          {/* Top accent gradient bar */}
          <div
            class={`absolute top-0 inset-x-0 h-[3px] bg-gradient-to-r ${service.color.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}
          />

          {/* Hover glow */}
          <div
            class="absolute -top-20 -right-20 w-40 h-40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-3xl pointer-events-none"
            style={`background: ${service.color.glow}`}
          />

          <div class="relative">
            {/* Icon */}
            <div
              class="w-14 h-14 rounded-xl flex items-center justify-center mb-6 transition-all duration-500 group-hover:scale-110 group-hover:shadow-lg"
              style={`background: ${service.color.bg}; box-shadow: 0 0 0 1px ${service.color.border}`}
            >
              <svg
                class="w-6 h-6 transition-transform duration-500 group-hover:scale-105"
                fill="none"
                stroke={service.color.icon}
                viewBox="0 0 24 24"
              >
                <Fragment set:html={service.icon} />
              </svg>
            </div>

            <h3 class="text-[1.1rem] font-semibold text-gray-900 tracking-tight">{service.title}</h3>
            <p class="mt-2.5 text-gray-500 leading-relaxed text-[0.9rem]">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.03),
      0 4px 12px rgba(0, 0, 0, 0.02);
  }
  .service-card:hover {
    border-color: transparent;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.06),
      0 12px 40px rgba(0, 0, 0, 0.04);
  }
</style>
